# 기본: 텍스트 파일은 Git이 자동 감지, 저장소에는 LF로 정규화
* text=auto eol=lf

# 명시적으로 LF로 강제할 텍스트 파일
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.vue       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.svg       text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# 바이너리 (변환 금지)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
